# URL pública do site (sem barra no final)
SITE_URL=https://infinity-corebots.vercel.app

# Discord Application (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://infinity-corebots.vercel.app/api/auth/discord/callback

# Webhook do canal onde chegam os logins
# Discord → Canal → Editar canal → Integrações → Webhooks → Novo webhook
DISCORD_WEBHOOK_URL=

# Segredo para assinar a sessão (pode ser qualquer string longa)
SESSION_SECRET=
